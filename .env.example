# =============================================================================
# Shayga — Environment Variables
# =============================================================================
# Copy to .env for local dev. Never commit .env.
# For CI/CD env vars, see docs/ci-cd.md
# =============================================================================

# --- Server ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Database (Neon Postgres) ---
# Local: postgres://shayga:shayga_dev@localhost:5432/shayga
# CI/Prod: set via Vercel project env vars per environment
DATABASE_URL=postgres://shayga:shayga_dev@localhost:5432/shayga

# --- Payload ---
PAYLOAD_SECRET=nTzQPCOAwugmzyAin1KtORms5WE3L/qls/Kz5U5pifs=

# --- Seed Credentials ---
SEED_ADMIN_EMAIL=admin@shayga.in
SEED_ADMIN_PASSWORD=admin123

# --- Cloudflare R2 / S3 ---
# Local: MinIO at localhost:9000 (see infra/dev-services.yml)
# CI/Prod: set via Vercel project env vars per environment
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=shayga-dev
R2_REGION=us-east-1

# --- Transactional Email ---
# Production: Resend (comment out MAILPIT_* to use Resend)
RESEND_API_KEY=re_xxxx

# Dev: Mailpit local SMTP (presence of MAILPIT_SMTP_HOST switches the adapter)
# Web UI: http://localhost:8025  |  Started via: pnpm dev:services
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_API_URL=http://localhost:8025/api/v1

# Sender identity (both dev and prod)
EMAIL_FROM_NAME=Shayga
EMAIL_FROM_ADDRESS=noreply@shayga.in

# Admin inbox for order/system notifications (overrides Site Settings value)
ADMIN_EMAIL=orders@shayga.in

# --- Better Auth (Customer Auth) — Phase 2 ---
BETTER_AUTH_SECRET=tMVDjroblWvt/QvkAssW1JE6R3TzQIGQ3Y44BZrV86c=

# --- OAuth / Social Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# --- Twilio (SMS / OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Razorpay (Payments) — Phase 3 ---
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=change-me

# --- Optional ---
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://xxxx.ingest.sentry.io/xxxx
